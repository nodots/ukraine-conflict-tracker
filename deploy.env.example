# Copy to `.env` (gitignored) next to docker-compose.yml on the VPS.

# Database (the compose db service is created with these).
DB_USER=ukraine
DB_PASSWORD=change-me-to-a-strong-secret
DB_NAME=ukraine_tracker

# Your domain — enables automatic HTTPS in Caddy. Leave blank to serve plain
# HTTP on :80 (e.g. while testing or if Cloudflare terminates TLS in front).
PUBLIC_DOMAIN=tracker.example.com
# Used only for the API CORS header (same-origin via Caddy makes this moot).
PUBLIC_ORIGIN=https://tracker.example.com

# NASA FIRMS thermal layer (optional). Free key: https://firms.modaps.eosdis.nasa.gov/api/map_key/
FIRMS_MAP_KEY=

# UCDP GED JSON API token (x-ucdp-access-token header). Only needed for the
# occasional UCDP refresh (see docker-compose.yml header). Request one at
# https://ucdp.uu.se/apidocs/.
UCDP_API_TOKEN=

# UTC wall-clock time (HH:MM) for the daily ingest. Default 07:30 is after
# GDELT publishes the prior day's export (~06:00 UTC), so each run captures the
# day that just ended rather than straddling the publish window.
INGEST_TIME_UTC=07:30
