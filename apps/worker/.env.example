# Worker
DATABASE_URL=postgresql://ukraine:ukraine@localhost:5433/ukraine_tracker

# Ingestion control
INGEST_MODE=backfill              # backfill | daily
BACKFILL_MONTHS=6
EVENT_SOURCE=acled                # acled | gdelt | ucdp | warspotting | mock (comma-separated for several, e.g. gdelt,warspotting)
CONTROL_SOURCE=deepstate-github   # deepstate-github | deepstate | mock

# ACLED — current API is OAuth2 (the legacy key+email endpoint was retired
# 2025-09-15). Use a myACLED account email + password; Google SSO does NOT work
# because the password grant needs a real password (set one via "Forgot
# password" if you signed up with Google).
# Note: ACLED's license requires attribution and forbids redistribution of raw data.
ACLED_EMAIL=
ACLED_PASSWORD=

# NASA FIRMS thermal anomalies (active fires) — optional corroborating layer.
# Free instant MAP_KEY: https://firms.modaps.eosdis.nasa.gov/api/map_key/
# Only runs when FIRMS_MAP_KEY is set; FIRMS_DAYS = recent window to pull (NRT
# only covers ~the last 2 months).
FIRMS_MAP_KEY=
FIRMS_DAYS=14

# WarSpotting — visually-confirmed Russian equipment losses (EVENT_SOURCE=warspotting).
# Free + ungated; only geolocated losses are ingested. A descriptive User-Agent
# is required (the API returns 520 without one). Defaults are usually fine.
WARSPOTTING_BASE=https://ukr.warspotting.net/api
WARSPOTTING_USER_AGENT=ukraine-conflict-tracker (+https://osint.nodots.com)
