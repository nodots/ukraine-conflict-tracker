# SITE_ADDRESS is set by docker-compose from PUBLIC_DOMAIN, defaulting to :80
# when no domain is configured (a real domain enables automatic HTTPS). The
# default is resolved in compose because Caddy's {$VAR:default} only applies when
# the variable is unset, not when set-but-empty.
{$SITE_ADDRESS} {
	encode gzip

	# API → api container (path is preserved: /api/... → api:6732/api/...)
	handle /api/* {
		reverse_proxy api:6732
	}

	# Static SPA with client-side routing fallback.
	handle {
		root * /srv
		try_files {path} /index.html
		file_server
	}
}
